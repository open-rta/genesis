{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-rta.org/genesis/schemas/oversight-record.schema.json",
  "title": "OversightRecord",
  "type": "object",
  "additionalProperties": false,
  "required": ["oversight_id", "objective_id", "observer", "observed_at", "status_snapshot"],
  "properties": {
    "oversight_id": { "type": "string", "minLength": 1 },
    "objective_id": { "type": "string", "minLength": 1 },
    "observer": { "type": "string", "minLength": 1 },
    "observed_at": { "type": "string", "format": "date-time" },
    "status_snapshot": { "type": "string", "minLength": 1 },
    "notes": { "type": "string" }
  }
}
