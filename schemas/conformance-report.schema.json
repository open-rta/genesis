{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-rta.org/genesis/schemas/conformance-report.schema.json",
  "title": "ConformanceReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "runtime_name",
    "runtime_version",
    "open_rta_version",
    "supported_laws",
    "evidence",
    "limitations",
    "declared_at"
  ],
  "properties": {
    "report_id": { "type": "string", "minLength": 1 },
    "runtime_name": { "type": "string", "minLength": 1 },
    "runtime_version": { "type": "string", "minLength": 1 },
    "open_rta_version": { "type": "string", "minLength": 1 },
    "supported_laws": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 },
      "required": ["objective", "authority", "trace", "oversight", "control", "replay"]
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "declared_at": { "type": "string", "format": "date-time" }
  }
}
