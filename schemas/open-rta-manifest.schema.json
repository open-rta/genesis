{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-rta.org/genesis/schemas/open-rta-manifest.schema.json",
  "title": "OpenRTAManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "open_rta_version",
    "runtime",
    "compliance",
    "evidence",
    "attestation"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "minLength": 1
    },
    "open_rta_version": {
      "type": "string",
      "minLength": 1
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "vendor": { "type": "string", "minLength": 1 },
        "homepage": { "type": "string", "minLength": 1 }
      }
    },
    "compliance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["laws_claimed", "level_claimed"],
      "properties": {
        "laws_claimed": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "level_claimed": {
          "type": "string",
          "enum": ["L0", "L1", "L2", "L3", "L4"]
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/evidenceReference"
      },
      "minProperties": 1
    },
    "test_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["by", "timestamp", "statement"],
      "properties": {
        "by": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" },
        "statement": { "type": "string", "minLength": 1 },
        "signature": { "type": "string", "minLength": 1 }
      }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "evidenceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "ref"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["file", "artifact", "doc", "url"]
        },
        "ref": { "type": "string", "minLength": 1 },
        "schema": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "digest": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "value"],
          "properties": {
            "algorithm": { "type": "string", "minLength": 1 },
            "value": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
